# Üretim build: tarayıcıdan çağrılacak API kökü (sonunda /api olmalı; sondaki / opsiyonel)
# Örnek: https://gametracker-api.onrender.com/api
# Boş bırakın: npm run dev sırasında istekler /api ile gider ve Vite proxy backend’e yönlendirir.
VITE_API_BASE_URL=

# İsteğe bağlı: dotnet run adresi Vite varsayılanından (5118) farklıysa
# VITE_DEV_PROXY_TARGET=http://localhost:5118
