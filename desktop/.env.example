# Masaüstü build için renderer (Vite) ortamı.
# Bu dosyayı DOĞRUDAN Electron değil, `npm --prefix ../frontend run build` çağrısı okur
# (Vite, build sırasında `frontend/.env*` dosyalarını yükler). Desktop sürümünde SPA
# `file://` üzerinden yüklendiği için `VITE_API_BASE_URL` **mutlaka** mutlak URL olmalıdır;
# boş bırakılırsa apiClient `/api`'ye düşer ve `file:///api/...` çözülemediği için istekler başarısız olur.
#
# Kullanım:
# 1) Bu dosyayı `frontend/.env.production` olarak kopyalayın (veya doğrudan shell'de export edin).
# 2) Aşağıdaki değeri gerçek üretim API köküyle doldurun.
# 3) `cd desktop && npm run build` çalıştırın.

VITE_API_BASE_URL=https://gametracker-api.example.com/api

# Geliştirme (PoC): Vite dev server'ı hedefleyen Electron penceresi için.
# `desktop/` içinde `npm run dev` bu değeri kullanır; dev server zaten çalışıyor olmalı
# (`frontend`'de `npm run dev`).
GAMETRACKER_DEV_SERVER_URL=http://localhost:5173
